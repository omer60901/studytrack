{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
    ,"types": ["node", "jest"]
  },
  "include": ["src", "src/types/**/*.d.ts"],
  "exclude": ["node_modules", "tests", "dist"]
}
